# 复制本文件为同目录下的 .env 后填写（.env 已被 .gitignore 忽略，勿提交仓库）
# 申请地址: https://finnhub.io/register
FINNHUB_API_KEY=
# 行情源: auto | eastmoney | finnhub | yahoo（大陆无密钥时 auto 走东方财富）
QUOTE_PROVIDER=auto
# AI 分析（OpenAI 兼容 POST /v1/chat/completions）
# 通义千问（百炼）：填 DASHSCOPE_API_KEY 即可，默认 base 为兼容模式、模型 qwen-plus；可选 QWEN_MODEL / DASHSCOPE_MODEL
# 默认开启百炼联网搜索（enable_search + forced_search，检索近 30 天）；LLM_ENABLE_SEARCH=false 可关闭
DASHSCOPE_API_KEY=
# QWEN_MODEL=qwen-plus
# LLM_ENABLE_SEARCH=true
# LLM_SEARCH_FRESHNESS_DAYS=30
# 其他兼容网关：也可用 OPENAI_API_KEY + OPENAI_BASE_URL + OPENAI_MODEL
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
